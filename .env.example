# Production URL — used for canonical links, sitemap, and social previews
NEXT_PUBLIC_SITE_URL=https://chetnabhadkare.com

# Cal.com — "Schedule" on /audit opens this in a new tab
NEXT_PUBLIC_BOOKING_URL=https://cal.com/your-username/15min

# Footer + mailto fallback (optional until public launch)
NEXT_PUBLIC_CONTACT_EMAIL=hello@chetnabhadkare.com
NEXT_PUBLIC_LINKEDIN_URL=https://www.linkedin.com/in/your-profile

# Review-only gate — server-side, NEVER prefix with NEXT_PUBLIC_
# When set, the whole site asks for HTTP Basic Auth (any username + this password).
# Leave unset for a fully public site. Remove + redeploy to open the gates.
SITE_ACCESS_PASSWORD=

# About portrait — drop a headshot at public/images/chetna.jpg (slot auto-detects it)
# Until then the About frame shows a CB monogram placeholder.